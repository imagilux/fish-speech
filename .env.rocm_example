# Environment configuration for ROCm / AMD RDNA GPUs.
# Copy this file to .env and adjust values for your setup:
#   cp .env.rocm_example .env

# ── Model checkpoints ────────────────────────────────────────────────────────
# Path (relative to repo root) to the LLM checkpoint.
# INT8 quantized (6.5 GB, recommended for 16 GB VRAM):
LLAMA_CHECKPOINT_PATH=checkpoints/fish-speech-s2-pro-int8
# Full precision (11 GB):
# LLAMA_CHECKPOINT_PATH=checkpoints/s2-pro

# Path to the DAC codec weights.
DECODER_CHECKPOINT_PATH=checkpoints/fish-speech-s2-pro-int8/codec.pth
# DECODER_CHECKPOINT_PATH=checkpoints/s2-pro/codec.pth

# ── GPU / ROCm ────────────────────────────────────────────────────────────────
# GID of the host's render group. Default is 993; override if your system
# differs (run: stat -c '%g' /dev/kfd).
# RENDER_GID=993

# Fraction of GPU VRAM PyTorch may allocate (0 = no limit).
# VRAM_FRACTION=0

# ── Inference tuning ─────────────────────────────────────────────────────────
# Maximum sequence length for the LLM KV cache.
# 4096 is sufficient for most TTS inputs and keeps VRAM usage low (~0.6 GB).
# Increase up to 32768 only for very long texts with ample VRAM headroom.
MAX_SEQ_LEN=4096
